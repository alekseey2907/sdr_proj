[Unit]
Description=SkyShield FastAPI Backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/skyshield
EnvironmentFile=-/etc/skyshield/skyshield.env
ExecStart=/opt/skyshield/scripts/run_backend.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target